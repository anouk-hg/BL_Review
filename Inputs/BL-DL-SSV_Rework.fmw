FACTORY_DEF {*} TestFactory FACTORY_NAME { Remove_comments_about_duplicates } INPUT FEATURE_TYPE Remove_comments_about_duplicates_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>VALIDATION<space>COMMENT<space>SSV<closeparen>,Remove_comments_about_duplicates) CONTAINS uplicat ENCODED } CASE_INSENSITIVE_TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>VALIDATION<space>COMMENT<space>SSV<closeparen>,Remove_comments_about_duplicates) CONTAINS oublo ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1 OR 2" OUTPUT PASSED_0 FEATURE_TYPE Remove_comments_about_duplicates_Duplicate TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>SSV<space>STATUS<closeparen>,Remove_comments_about_duplicates) = NOT<space>EXISTING ENCODED } TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>sum<openparen><at>Value<openparen>SSV<space>BU<space>COUNT<space>CHK<closeparen><comma><at>Value<openparen>SSV<space>LU<space>COUNT<space>CHK<closeparen><closeparen>,Remove_comments_about_duplicates) = 0 ENCODED } TEST { SSV<space>BU<space>COUNT<space>CHK ATTRIBUTE_HAS_A_VALUE "" ENCODED } TEST { SSV<space>LU<space>COUNT<space>CHK NOT_ATTRIBUTE_HAS_A_VALUE "" ENCODED } BOOLEAN_OPERATOR COMPOSITE COMPOSITE_TEST_EXPR "1 AND ( 2 OR ( NOT 3 AND 4 ))" OUTPUT PASSED_1 FEATURE_TYPE Remove_comments_about_duplicates_NOT<space>EXISTING OUTPUT FAILED FEATURE_TYPE Remove_comments_about_duplicates_<lt>UNFILTERED<gt>
