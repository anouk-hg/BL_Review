    ATTR_ACTION { "APP<space>SSV<space>BU<space>COUNT" "APP<space>SSV<space>BU<space>COUNT" "" "buffer" "NO_OP" }      ATTR_ACTION { "APP<space>SSV<space>BUILDING<space>GROUP" "APP<space>SSV<space>BUILDING<space>GROUP" "" "buffer" "NO_OP" }      ATTR_ACTION { "APP<space>SSV<space>BUILDING<space>TYPE" "APP<space>SSV<space>BUILDING<space>TYPE" "" "buffer" "NO_OP" }      ATTR_ACTION { "APP<space>SSV<space>DEPLOYMENT<space>TYPE" "APP<space>SSV<space>DEPLOYMENT<space>TYPE" "" "buffer" "NO_OP" }      ATTR_ACTION { "APP<space>SSV<space>LOW<space>FLOOR" "APP<space>SSV<space>LOW<space>FLOOR" "" "buffer" "NO_OP" }      ATTR_ACTION { "APP<space>SSV<space>LU<space>COUNT" "APP<space>SSV<space>LU<space>COUNT" "" "buffer" "NO_OP" }      ATTR_ACTION { "APP<space>SSV<space>QUADRANT" "APP<space>SSV<space>QUADRANT" "" "buffer" "NO_OP" }      ATTR_ACTION { "APP<space>SSV<space>SU<space>COUNT" "APP<space>SSV<space>SU<space>COUNT" "" "buffer" "NO_OP" }      ATTR_ACTION { "APP<space>SSV<space>TOTAL<space>UNITS" "APP<space>SSV<space>TOTAL<space>UNITS" "" "buffer" "NO_OP" }      ATTR_ACTION { "APP<space>SSV<space>UPPER<space>FLOOR" "APP<space>SSV<space>UPPER<space>FLOOR" "" "buffer" "NO_OP" }      ATTR_ACTION { "DMP<space>LOCATION<space>CHK" "DMP<space>LOCATION<space>CHK" "" "buffer" "NO_OP" }      ATTR_ACTION { "Doubles" "Doubles" "" "buffer" "NO_OP" }      ATTR_ACTION { "SSV<space>COMPANY" "SSV<space>COMPANY" "" "buffer" "NO_OP" }      ATTR_ACTION { "TSA<space>COMPANY" "TSA<space>COMPANY" "" "buffer" "NO_OP" }      ATTR_ACTION { "REWORK<space>STATUS<space>SSV" "REWORK<space>STATUS<space>SSV" "" "buffer" "NO_OP" }      ATTR_ACTION { "REWORK<space>STATUS<space>TSA" "REWORK<space>STATUS<space>TSA" "" "buffer" "NO_OP" }      ATTR_ACTION { "REFUSAL<space>RESPONSIBILITY<space>SSV" "REFUSAL<space>RESPONSIBILITY<space>SSV" "" "buffer" "NO_OP" }      ATTR_ACTION { "REFUSAL<space>RESPONSIBILITY<space>TSA" "REFUSAL<space>RESPONSIBILITY<space>TSA" "" "buffer" "NO_OP" }      ATTR_ACTION { "REFUSAL<space>REASON<space>SSV" "REFUSAL<space>REASON<space>SSV" "" "buffer" "NO_OP" }      ATTR_ACTION { "REFUSAL<space>REASON<space>TSA" "REFUSAL<space>REASON<space>TSA" "" "buffer" "NO_OP" }      ATTR_ACTION { "ACTION<space>REQUIRED<space>FROM<space>SSV" "ACTION<space>REQUIRED<space>FROM<space>SSV" "" "buffer" "NO_OP" }      ATTR_ACTION { "ACTION<space>REQUIRED<space>FROM<space>TSA" "ACTION<space>REQUIRED<space>FROM<space>TSA" "" "buffer" "NO_OP" }      ATTR_ACTION { "SSV<space>STATUS" "SSV<space>STATUS" "" "buffer" "NO_OP" }      ATTR_ACTION { "MDU_ID" "MDU_ID" "" "int64" "NO_OP" }      ATTR_ACTION { "" "BG_Total" "<at>sum<openparen><at>Value<openparen>APP<space>SSV<space>LU<space>COUNT<closeparen><comma><at>Value<openparen>APP<space>SSV<space>BU<space>COUNT<closeparen><closeparen>" "varchar<openparen>200<closeparen>" "SET_TO" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeManager_3_OUTPUT        }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { AttributeRemover_2 }    INPUT  FEATURE_TYPE AttributeManager_3_OUTPUT    OUTPUT { FEATURE_TYPE AttributeRemover_2_OUTPUT        @RemoveAttributes(fme_encoded,ACTION<space>REQUIRED<space>FROM<space>SSV,ACTION<space>REQUIRED<space>FROM<space>TSA,APP<space>SSV<space>BLDG<space>GRP<space>INDIV<space>TREATMENT,APP<space>SSV<space>BLDG<space>GRP<space>MAIN<space>ADDRESS,APP<space>SSV<space>BU<space>COUNT,APP<space>SSV<space>BUILDING<space>GROUP,APP<space>SSV<space>BUILDING<space>TYPE,APP<space>SSV<space>DEPLOYMENT<space>TYPE,APP<space>SSV<space>LOW<space>FLOOR,APP<space>SSV<space>LU<space>COUNT,APP<space>SSV<space>QUADRANT,APP<space>SSV<space>SU<space>COUNT,APP<space>SSV<space>TOTAL<space>UNITS,APP<space>SSV<space>UPPER<space>FLOOR,DMP<space>AREA<space>AREA<space>ID,DMP<space>AREA<space>NAME,DMP<space>BELMAP<space>LU<space>COUNT,DMP<space>BUILDING<space>KEY,DMP<space>CITY,DMP<space>HOUSENUMBER,DMP<space>IN<space>SCOPE,DMP<space>LOCATION<space>CHK,DMP<space>MUNICIPALITY,DMP<space>POP<space>AREA<space>NAME,DMP<space>POSTAL<space>CODE,DMP<space>STREET,Doubles,MDU_ID,MDU_Total,REFUSAL<space>REASON<space>SSV,REFUSAL<space>REASON<space>TSA,REFUSAL<space>RESPONSIBILITY<space>SSV,REFUSAL<space>RESPONSIBILITY<space>TSA,REWORK<space>STATUS<space>SSV,REWORK<space>STATUS<space>TSA,SSV<space>COMPANY,SSV<space>STATUS,task,TSA<space>COMPANY)        $(AttributeRemover_2_LIST_FUNC)         }
