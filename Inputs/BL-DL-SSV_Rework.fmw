FACTORY_DEF {*} DuplicateRemoverFactory    FACTORY_NAME { Remove_duplicate_MDU }    COMMAND_PARM_EVALUATION SINGLE_PASS    SUPPORTS_FEATURE_TABLES    INPUT  FEATURE_TYPE Sort_by_address_-_validation_status_-_total_LU_SORTED    KEY_ATTRIBUTES { DMP<space>HOUSENUMBER DMP<space>POSTAL<space>CODE DMP<space>STREET }    INPUT_IS_ORDERED { YES }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { UNIQUE FEATURE_TYPE Remove_duplicate_MDU_UNIQUE         }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO AttributeRemover_LIST_FUNC }    } else {        puts "MACRO AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { AttributeRemover }    INPUT  FEATURE_TYPE Remove_duplicate_MDU_UNIQUE    OUTPUT { FEATURE_TYPE AttributeRemover_OUTPUT        @RemoveAttributes(fme_encoded,ACT<space>HP<space>CY,ACT<space>HP<space>CY<space>DEADLINE,ACT<space>SSV<space>CY,ACT<space>SSV<space>DEADLINE,ACT<space>UNIFIBER,ACT<space>UNIFIBER<space>DATE,APP<space>CCP<space>SSV<space>SU<space>COUNT,APP<space>CHK<space>SU<space>COUNT,APP<space>PROCESSED,Audit<space>report,Audit<space>report<space>date,BLD<space>ALL<space>READY<space>STATUS,BLD<space>COMPANY,BLD<space>FIBER<space>BLOWN<space>ACTUAL<space>DATE,BLD<space>FIBER<space>BLOWN<space>PLANNED<space>DATE,BLD<space>FIBER<space>BLOWN<space>STATUS,BLD<space>FIBER<space>SPLICED<space>ACTUAL<space>DATE,BLD<space>FIBER<space>SPLICED<space>PLANNED<space>DATE,BLD<space>FIBER<space>SPLICED<space>STATUS,BLD<space>INTRO<space>ACTUAL<space>DATE,BLD<space>INTRO<space>PLANNED<space>DATE,BLD<space>INTRO<space>STATUS,BLD<space>SSV<space>USABILITY,BLD<space>VC<space>ACTUAL<space>DATE,BLD<space>VC<space>PLANNED<space>DATE,BLD<space>VC<space>STATUS,Building<space>Group<space>Check,Cable<solidus>material<space>trajectory,CCP<space>CHECK<space>DONE,CCP<space>CLEANUP<space>COMMENT,CCP<space>cleanup<space>scope,CCP<space>SSV<space>BU<space>COUNT,CCP<space>SSV<space>LOW<space>FLOOR,CCP<space>SSV<space>LU<space>COUNT,CCP<space>SSV<space>QUADRANT,CCP<space>SSV<space>TOTAL<space>UNITS,CCP<space>SSV<space>UPPER<space>FLOOR,CHK<space>SSV<space>BU<space>COUNT,CHK<space>SSV<space>DOC<space>LINK,CHK<space>SSV<space>LU<space>COUNT,CHK<space>SSV<space>QUADRANT,CHK<space>SSV<space>TOTAL<space>UNITS,CHK<space>SSV<space>UPPER<space>FLOOR,CHK<space>TSA<space>DOC<space>FOR<space>SIGNATURE,CHK<space>TSA<space>DOC<space>SIGNED,CHK<space>TSA<space>STATUS,Contact<space>Details,item_id,Picture<space>Quality,PRIORITY,PST<space>CENTRAL<space>POP<space>STATUS,PST<space>DEL<space>HCA,PST<space>DEL<space>STAT<space>CODE<space>DESC,PST<space>HP<space>ACTUAL<space>DATE,PST<space>HP<space>PLANNED<space>DATE,Quadrant<space>Design,SSV<space>ACTUAL<space>DATE,SSV<space>AGENT,SSV<space>BLDG<space>GRP<space>MAIN<space>ADDRESS<space>CHK,SSV<space>BLOCK,SSV<space>BU<space>COUNT<space>CHK,SSV<space>DOC<space>LINK,SSV<space>LU<space>COUNT<space>CHK,SSV<space>PLANNED<space>DATE,SSV<space>REGISTRATION<space>STATUS,SSV<space>SU<space>COUNT<space>CHK,SSV<space>SYNDIC,SSV<space>SYNDIC<space>MAIL,SSV<space>SYNDIC<space>NAME,SSV<space>SYNDIC<space>PHONE,SSV<space>TIMESTAMP,SSV<space>TOTAL<space>UNITS<space>CHK,SSV<space>validation<space>counter,SSV<space>validation<space>date,SSV<space>VALIDATION<space>STATUS,SSV<space>VALIDATOR,STS<space>ACTUAL<space>DATE,STS<space>DOC<space>LINK,STS<space>PARTNER,STS<space>PLANNED<space>DATE,STS<space>QUADRANT,STS<space>STATUS,STS<space>UNITS<space>COUNT,TSA<space>1ST<space>REMINDER<space>DATE,TSA<space>2ND<space>REMINDER<space>DATE,TSA<space>3RD<space>REMINDER<space>DATE,TSA<space>4TH<space>REMINDER<space>DATE,TSA<space>DOC<space>FOR<space>SIGNATURE,TSA<space>DOC<space>SIGNED,TSA<space>GENERAL<space>ASSEMBLY<space>DATE,TSA<space>NEGOTIATOR,TSA<space>NEGOTIATOR<space>COMMENTS,TSA<space>READY<space>TO<space>SEND<space>DATE,TSA<space>REFUSED<space>DATE,TSA<space>REGISTRATION<space>STATUS,TSA<space>SENT<space>DATE,TSA<space>SIGNED<space>DATE,TSA<space>STATUS,TSA<space>validation<space>counter,TSA<space>validation<space>date,TSA<space>VALIDATION<space>STATUS,VALIDATION<space>COMMENT<space>SSV,VALIDATION<space>COMMENT<space>TSA)        $(AttributeRemover_LIST_FUNC)         }
