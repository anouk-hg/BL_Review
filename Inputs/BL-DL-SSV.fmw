FACTORY_DEF {*} SortFactory    FACTORY_NAME { Sorter }    INPUT  FEATURE_TYPE AttributeManager_OUTPUT    SORT_ALPHA_AS_UTF8 { YES }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    SORT_BY { DMP<space>POSTAL<space>CODE NATURAL ASCENDING DMP<space>STREET NATURAL ASCENDING DMP<space>HOUSENUMBER NATURAL ASCENDING SSV<space>VALIDATION<space>STATUS NATURAL DESCENDING APP<space>SSV<space>TOTAL<space>UNITS NATURAL DESCENDING }    OUTPUT { SORTED FEATURE_TYPE Sorter_SORTED          }
